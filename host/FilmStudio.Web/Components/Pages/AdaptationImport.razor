@page "/adaptation/import"
@page "/adaptation/book"
@inherits AdaptationPageBase
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Adaptation · Import</PageTitle>

<AdaptationShell Host="this" Step="import">
    @if (Status is not null)
    {
        <div class="card mb-3">
            <div class="card-header">Import</div>
            <div class="card-body">
                <p class="small text-muted mb-3">
                    Bring in a source for this project:
                    a <strong>screenplay</strong> file, a <strong>PDF</strong> book, or plain <strong>TXT</strong>.
                    You’ll review and approve the screenplay next.
                </p>

                <div class="mb-2">
                    <label class="form-label small">Source file</label>
                    <InputFile OnChange="OnSourceSelected"
                               class="form-control form-control-sm"
                               accept=".fountain,.spmd,.pdf,.txt"
                               disabled="@(Busy || JobRunning)" />
                </div>
                <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
                    <button class="btn btn-primary btn-sm"
                            disabled="@(Busy || JobRunning || _sourceFile is null)"
                            @onclick="ImportSourceAsync">
                        Import
                    </button>
                    @if (_sourceFile is not null)
                    {
                        <span class="small text-muted">@_sourceFile.Name · @SourceKindLabel</span>
                    }
                </div>

                @* Status snapshot *@
                <ul class="list-unstyled small mb-3">
                    <li>
                        PDF:
                        @if (Status.Book.PdfExists)
                        {
                            <code>@Status.Book.PdfName</code>
                        }
                        else
                        {
                            <span class="text-muted">none</span>
                        }
                    </li>
                    <li>
                        Story text:
                        @(Status.Book.BookTextExists
                            ? $"{Status.Book.BookTextBytes:N0} bytes · {Status.Book.TextWords ?? 0} words"
                            : "missing")
                        @if (Status.Book.ReadyForStage1)
                        {
                            <span class="badge text-bg-success ms-1">ready</span>
                        }
                    </li>
                    <li>
                        Screenplay draft:
                        @if (Status.Screenplay.DraftExists)
                        {
                            <span>
                                <strong>@(Status.Screenplay.Title ?? "Untitled")</strong>
                                · @Status.Screenplay.SceneHeadingCount scenes
                            </span>
                            @if (Status.Screenplay.Signed && !Status.Screenplay.Dirty)
                            {
                                <span class="badge text-bg-success ms-1">approved</span>
                            }
                            else
                            {
                                <span class="badge text-bg-warning text-dark ms-1">needs review</span>
                            }
                        }
                        else if (Status.Stage1.Present && Status.Stage1.SceneCount > 0)
                        {
                            <span>
                                <strong>@(Status.Stage1.MovieTitle ?? "Untitled")</strong>
                                · @Status.Stage1.SceneCount scenes
                            </span>
                            <span class="badge text-bg-success ms-1">ready</span>
                        }
                        else
                        {
                            <span class="text-muted">not set yet</span>
                        }
                    </li>
                    @if (Status.Book.BookTextExists)
                    {
                        <li class="text-muted">
                            text quality: @(Status.Book.TextQuality ?? "—")
                            · page images: @Status.Book.PageImageCount
                        </li>
                    }
                </ul>

                @if (Status.Book.Notes.Count > 0)
                {
                    <ul class="small text-muted mb-3">
                        @foreach (var n in Status.Book.Notes.Take(4))
                        {
                            <li>@n</li>
                        }
                    </ul>
                }

                @* Book-only actions after PDF/TXT import *@
                @if (Status.Book.PdfExists || Status.Book.BookTextExists)
                {
                    <div class="border-top pt-3 mb-2">
                        <div class="small fw-semibold mb-2">From book or text</div>
                        <div class="d-flex flex-wrap gap-2 mb-2">
                            <button class="btn btn-outline-primary btn-sm"
                                    disabled="@(Busy || JobRunning || (!Status.Book.PdfExists && !Status.Book.BookTextExists))"
                                    @onclick="() => PrepareBookAsync(forceVision: false)">
                                Prepare text
                            </button>
                            <button class="btn btn-outline-secondary btn-sm"
                                    disabled="@(Busy || JobRunning || !Status.XaiConfigured || (!Status.Book.PdfExists && Status.Book.PageImageCount == 0))"
                                    @onclick="() => PrepareBookAsync(forceVision: true)">
                                Re-read book pages
                            </button>
                        </div>
                        <p class="small text-muted mb-0">
                            Use after a PDF (or messy text). Then open Screenplay to draft and approve.
                        </p>
                        @if (Status.Book.BookTextExists)
                        {
                            <button class="btn btn-outline-success btn-sm mt-2"
                                    disabled="@(Busy || JobRunning)"
                                    @onclick="DraftFromBookAsync">
                                Create screenplay draft
                            </button>
                        }
                    </div>
                }

                @if (!string.IsNullOrEmpty(Status.Book.Preview))
                {
                    <details class="mt-3">
                        <summary class="small text-muted">Text preview</summary>
                        <pre class="small bg-light border rounded p-2 mt-1" style="max-height:140px; overflow:auto; white-space:pre-wrap;">@Status.Book.Preview</pre>
                    </details>
                }

                <div class="d-flex flex-wrap gap-2 mt-3">
                    @if (CanContinueToScreenplay)
                    {
                        <a class="btn btn-success btn-sm" href="adaptation/screenplay">Continue to screenplay →</a>
                    }
                    @if (Status.Screenplay.ReadyForShots)
                    {
                        <a class="btn btn-outline-success btn-sm" href="adaptation/shots">Shot plan →</a>
                    }
                </div>
            </div>
        </div>
    }
</AdaptationShell>

@code {
    public override string StepKey => "import";

    private IBrowserFile? _sourceFile;

    private string SourceKindLabel =>
        IsFountainName(_sourceFile?.Name) ? "Screenplay"
        : IsPdfName(_sourceFile?.Name) ? "PDF"
        : IsTxtName(_sourceFile?.Name) ? "Text"
        : "file";

    private bool CanContinueToScreenplay =>
        Status is not null &&
        (Status.Screenplay.DraftExists ||
         Status.Book.ReadyForStage1 ||
         Status.Book.BookTextExists ||
         (Status.Stage1.Present && Status.Stage1.SceneCount > 0));

    private void OnSourceSelected(InputFileChangeEventArgs e)
    {
        _sourceFile = e.File;
        Message = $"Selected {_sourceFile.Name} ({_sourceFile.Size:N0} bytes)";
    }

    private async Task ImportSourceAsync()
    {
        if (_sourceFile is null) return;
        Busy = true;
        Error = null;
        Message = null;
        try
        {
            var name = _sourceFile.Name;
            if (IsFountainName(name))
            {
                const long max = 20 * 1024 * 1024;
                await using var stream = _sourceFile.OpenReadStream(max);
                var result = await Engine.ImportFountainAsync(ProjectId, name, stream);
                Message = result?.Message
                          ?? "Screenplay draft ready — review and approve next";
                _sourceFile = null;
                await LoadAsync();
                Nav.NavigateTo("adaptation/screenplay");
                return;
            }

            // PDF or TXT → project source
            const long maxBook = 80 * 1024 * 1024;
            await using (var stream = _sourceFile.OpenReadStream(maxBook))
            {
                await Engine.UploadBookAsync(ProjectId, name, stream);
            }

            if (IsTxtName(name))
            {
                // TXT often is already readable — offer draft immediately
                try
                {
                    var draft = await Engine.CreateScreenplayFromBookAsync(ProjectId);
                    Message = draft?.Message ?? "Draft ready — review on Screenplay";
                    _sourceFile = null;
                    await LoadAsync();
                    Nav.NavigateTo("adaptation/screenplay");
                    return;
                }
                catch
                {
                    // fall through to manual prepare path
                }
            }

            Message = IsPdfName(name)
                ? $"Saved {name}. Click Prepare text next."
                : $"Saved {name}. Continue to screenplay when text looks good.";
            _sourceFile = null;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            Busy = false;
        }
    }

    private async Task DraftFromBookAsync()
    {
        Busy = true;
        Error = null;
        try
        {
            var result = await Engine.CreateScreenplayFromBookAsync(ProjectId);
            Message = result?.Message ?? "Draft ready";
            await LoadAsync();
            Nav.NavigateTo("adaptation/screenplay");
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            Busy = false;
        }
    }

    private static bool IsFountainName(string? name) =>
        name is not null &&
        (name.EndsWith(".fountain", StringComparison.OrdinalIgnoreCase) ||
         name.EndsWith(".spmd", StringComparison.OrdinalIgnoreCase));

    private static bool IsPdfName(string? name) =>
        name is not null && name.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase);

    private static bool IsTxtName(string? name) =>
        name is not null && name.EndsWith(".txt", StringComparison.OrdinalIgnoreCase);
}
