@page "/adaptation/book"
@inherits AdaptationPageBase
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Adaptation · Book</PageTitle>

<AdaptationShell Host="this" Step="book">
    @if (Status is not null)
    {
        <div class="card">
            <div class="card-header">Book</div>
            <div class="card-body">
                @if (Status.Book.ReadyForStage1)
                {
                    <div class="alert alert-success py-2 small">
                        Book text ready for story outline
                        @if (!string.IsNullOrEmpty(Status.Book.BookKind))
                        {
                            <span>· @Status.Book.BookKind</span>
                        }
                        @if (Status.Book.SuggestedTotalMinutes is int m)
                        {
                            <span>· ~@m min</span>
                        }
                    </div>
                }
                else if (Status.Book.PdfExists || Status.Book.BookTextExists)
                {
                    <div class="alert alert-warning py-2 small">
                        Source on disk but text may need a cleaner re-read of the pages.
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary py-2 small">No book source yet — upload a PDF or TXT.</div>
                }

                <div class="d-flex flex-wrap gap-2 mb-3">
                    <button class="btn btn-primary btn-sm"
                            disabled="@(Busy || JobRunning || (!Status.Book.PdfExists && !Status.Book.BookTextExists))"
                            @onclick="() => PrepareBookAsync(forceVision: false)">
                        Prepare book
                    </button>
                    <button class="btn btn-outline-primary btn-sm"
                            disabled="@(Busy || JobRunning || !Status.XaiConfigured || (!Status.Book.PdfExists && Status.Book.PageImageCount == 0))"
                            @onclick="() => PrepareBookAsync(forceVision: true)">
                        Re-read book pages
                    </button>
                    @if (Status.Book.ReadyForStage1 || Status.Book.BookTextExists)
                    {
                        <a class="btn btn-outline-success btn-sm" href="adaptation/outline">Continue to story outline →</a>
                    }
                </div>
                <p class="small text-muted mb-3">
                    Extracts text from the book; for picture books, re-reads pages when text is unclear.
                </p>

                <ul class="list-unstyled small mb-3">
                    <li>
                        PDF:
                        @if (Status.Book.PdfExists)
                        {
                            <code>@Status.Book.PdfName</code>
                        }
                        else
                        {
                            <span class="text-muted">none</span>
                        }
                    </li>
                    <li>
                        Story text:
                        @(Status.Book.BookTextExists
                            ? $"{Status.Book.BookTextBytes:N0} bytes · {Status.Book.TextWords ?? 0} words"
                            : "missing")
                    </li>
                    <li>
                        quality: <code>@(Status.Book.TextQuality ?? "—")</code>
                        · garbage @(Status.Book.GarbageScore.ToString("0.00"))
                        · engine <code>@(Status.Book.TextEngine ?? "—")</code>
                    </li>
                    <li>page images: @Status.Book.PageImageCount</li>
                </ul>

                @if (Status.Book.Notes.Count > 0)
                {
                    <ul class="small text-muted">
                        @foreach (var n in Status.Book.Notes.Take(4))
                        {
                            <li>@n</li>
                        }
                    </ul>
                }

                <div class="mb-2">
                    <label class="form-label small">Upload PDF or TXT</label>
                    <InputFile OnChange="OnFileSelected" class="form-control form-control-sm" accept=".pdf,.txt" disabled="@Busy" />
                </div>
                <button class="btn btn-sm btn-outline-secondary" disabled="@(Busy || PendingFile is null)" @onclick="UploadAsync">
                    Save upload to project
                </button>
                <p class="small text-muted mt-2 mb-0">
                    After upload, click <strong>Prepare book</strong>. Plain TXT unlocks the story outline when quality is good.
                </p>

                @if (!string.IsNullOrEmpty(Status.Book.Preview))
                {
                    <details class="mt-3">
                        <summary class="small text-muted">Text preview</summary>
                        <pre class="small bg-light border rounded p-2 mt-1" style="max-height:140px; overflow:auto; white-space:pre-wrap;">@Status.Book.Preview</pre>
                    </details>
                }
            </div>
        </div>
    }
</AdaptationShell>

@code {
    public override string StepKey => "book";
}
